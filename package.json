{
  "name": "cenacle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "origin": "python -m room_origin.cenacle_origin.server",
    "test:origin": "python -m pytest room_origin/tests"
  },
  "dependencies": {
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@webgpu/types": "0.1.71",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "27.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12"
  }
}
