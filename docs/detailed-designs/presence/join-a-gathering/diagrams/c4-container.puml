@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Join a live gathering

Person(joiner, "Joiner", "Finds a room, previews, and enters")

System_Boundary(cenacle, "Cenacle") {
  Container(spa, "Prayer client", "Browser SPA — WebCodecs, WebTransport", "Join dialog, green room, and the live room")
  Container(origin, "Room origin", "HTTP/3 / WebTransport server", "Resolves codes, admits subscribers, enforces capacity, relays media")
  ContainerDb(registry, "Room registry", "Ephemeral in-memory store", "Open rooms and their codes; no media persisted")
}

Rel(joiner, spa, "Finds a room and previews in", "HTTPS")
Rel(spa, origin, "Resolves the room code and subscribes to media from", "WebTransport / HTTP/3")
Rel(origin, registry, "Looks up the room and code in")
@enduml
