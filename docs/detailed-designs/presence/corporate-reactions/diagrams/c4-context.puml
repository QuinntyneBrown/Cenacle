@startuml
!include <C4/C4_Context>
LAYOUT_WITH_LEGEND()
title System Context — Corporate reactions ("Amen")

Person(sender, "Sending participant", "Anyone present sends an amen or raised hand")
Person(others, "Other participants", "See the reaction surfaced near-instantly")
System(cenacle, "Cenacle", "Browser-native prayer gathering space; relays lightweight reactions within one small room")

