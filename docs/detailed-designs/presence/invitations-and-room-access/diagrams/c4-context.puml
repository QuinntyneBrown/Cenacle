@startuml
!include <C4/C4_Context>
LAYOUT_WITH_LEGEND()
title System Context — Invitations and room access

Person(host, "Host", "Opens Invite and shares the link, code, and QR")
Person(invitee, "Invited participant", "Receives the invite and joins the gathering")
