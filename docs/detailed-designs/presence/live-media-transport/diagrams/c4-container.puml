@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Live media transport

Person(participant, "Participant", "Publishes and views live presence")

System_Boundary(cenacle, "Cenacle") {
  Container(spa, "Prayer client", "Browser SPA — WebCodecs, WebTransport, WebGPU", "Captures, encodes, transports, decodes, and renders presence")
  Container(origin, "Room origin", "HTTP/3 / WebTransport server", "Relays media within one small room; persists no media")
  Container(registry, "Room registry", "Ephemeral in-memory store", "Open rooms and their members; authorizes admission")
}

Rel(participant, spa, "Sees and hears the gathering in", "HTTPS")
Rel(spa, origin, "Publishes WebCodecs-encoded media to", "WebTransport / HTTP/3")
Rel(origin, spa, "Relays other participants' media to", "WebTransport / HTTP/3")
Rel(origin, registry, "Checks room membership in")
@enduml
