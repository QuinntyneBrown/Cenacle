@startuml
title UML sequence behaviour — Private Word action with zero egress
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Person at prayer" as person
box "Frontend — Prayer client (PrivacyBoundary, on-device)" #E0F2FE
  participant "Word action surface" as surface
  participant "OnDeviceModel" as model
  participant "LocalStore" as store
  participant "NetworkGuard" as guard
  participant "PrivacySeal" as seal
end box
box "Backend — Room origin" #D1FADF
  participant "Room origin" as origin
end box

person -> surface : Request a Word action (reflection / Scripture / caption / journal save)
surface -> model : availability()
alt OnDeviceModel Ready
  model --> surface : Ready
  surface -> guard : Begin zero-egress check
  surface -> model : Run the action on the device (no server call)
  model --> surface : On-device result
  surface -> store : Persist private content on-device (L2-070)
  store --> surface : Stored locally
  surface -> guard : End zero-egress check
  guard --> surface : 0 outbound requests (L2-070)
  note over surface, origin : No message carrying private content crosses to the Room origin or any off-device endpoint (L2-069)
  surface -> seal : Show the "0 requests" affirmation (L2-070)
  seal --> person : Private result with the 0 requests seal
else OnDeviceModel Unavailable
  model --> surface : Unavailable
  surface --> person : Hide the feature; no reroute to any server (L2-069)
end
@enduml
